{
  "name": "trident-brain-v4.3.1-t3",
  "version": "4.3.1",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npx esbuild index.ts --bundle --platform=node --format=esm --target=node22 --external:@opencode-ai/plugin --external:zod --external:better-sqlite3 --outfile=../../dist/index.js",
    "test": "node ../../tests/properties.ts"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.16.0",
    "better-sqlite3": "^11.0.0",
    "peggy": "^4.0.0",
    "typescript": "^6.0.3",
    "wink-nlp": "^2.0.0",
    "xstate": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^8.0.0",
    "fast-check": "^3.0.0"
  }
}
